# Desarrollo local. Nunca pongas secretos reales en Git.
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=reemplazar-con-una-clave-nueva
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Producción: usa la URL del Transaction pooler de Supabase (puerto 6543).
DATABASE_URL=postgresql://USUARIO:CONTRASENA@HOST:6543/postgres?sslmode=require

# Opcional: solo habilita la imagen aleatoria de portada.
UNSPLASH_ACCESS_KEY=
